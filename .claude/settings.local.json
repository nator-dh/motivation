{
  "permissions": {
    "allow": [
      "Bash(go get *)",
      "Bash(go mod *)",
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(make help *)",
      "Bash(make build *)",
      "Bash(make clean *)",
      "Bash(brew info *)",
      "Bash(brew search *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/codemap-reminder.sh"
          }
        ]
      }
    ]
  }
}
